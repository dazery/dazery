s = [
    [45000, 52000, 49000],
    [47000, 48000, 51000],
    [50000, 50000, 50000],
    [60000, 58000, 59000],
    [42000, 43000, 44000],
    [48000, 49000, 50000],
    [51000, 52000, 53000],
    [46000, 47000, 48000],
    [62000, 61000, 63000],
    [40000, 41000, 42000],
    [59000, 60000, 58000],
    [54000, 64000, 60000]
]
for i in range(12):
    maxs = max(s[i])
    monthmax = [] # Находим ВСЕ месяцы с максимальной зарплатой
    for month in range(3):
        if s[i][month] == maxs: #если зарплата в этом месяце равна максимальной зарплате этого работника
            monthmax.append(month+1)#прибавляем 1, потому что month считает с 0, .append(...) — метод, который добавляет элемент в конец списка
            if len(monthmax) == 1:#длина списка (сколько месяцев с максимальной зарплатой)if len(...) == 1 — если максимум только в одном месяце...
                month_str = str(monthmax[0])#преобразует число в строку (чтобы можно было вывести)
            else:
                month_str = ", ".join(map(str, monthmax))
#map(str, months_with_max) — применяет функцию str() к каждому элементу списка (превращает все числа в строки)
            print(f"Работник {i + 1}: месяц(а) {month_str} (зарплата: {maxs} руб.)")
#f-строка (позволяет вставлять переменные прямо в текст)
#{month_str} — подставляем строку с номерами месяцев

#max_salary} — подставляем значение максимальной зарплаты
