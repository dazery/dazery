def sum_powers():#Вычисляет сумму 2^2 + 2^3 + ... + 2^10
    #без использования операции возведения в степень
    t = 0
    c = 4
    for _ in range(9):# 9 членов: от 2^2 до 2^10
        t+=c
        c *= 2 # умножаем на 2 для получения следующей степени

    return t

res = sum_powers()
print(res)
