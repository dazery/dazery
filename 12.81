text = "Сегодня был очень тяжелый день первого вторника месяца"

# Разбиваем предложение на слова по пробелам
words = text.split()

# Находим самое длинное слово
longest_word = max(words, key=len)
#key Вместо того чтобы сравнивать сами элементы, сначала применяет к каждому элементу функцию, указанную в key, и сравнивает результаты этой функции.
print(f"Самое длинное слово: '{longest_word}'")
print(f"Его длина: {len(longest_word)} букв")
