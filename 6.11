numbers = []
n = 0

while n < 10:
    num = (n+1)
    if num == 0:
        print(0)
        break
    numbers.append(num)
    n += 1

print(numbers)

#numbers — имя переменной, которая ссылается на список;

#.append() — метод для добавления элемента в конец списка;

#num — значение (или переменная), которое нужно добавить.
