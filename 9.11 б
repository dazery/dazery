salary = [
    [45000, 52000, 49000],
    [47000, 48000, 51000],
    [50000, 50000, 50000],
    [60000, 58000, 59000],
    [42000, 43000, 44000],
    [48000, 49000, 50000],
    [51000, 52000, 53000],
    [46000, 47000, 48000],
    [62000, 61000, 63000],
    [40000, 41000, 42000],
    [59000, 60000, 58000],
    [54000, 64000, 60000]
]

for month in range(3):  # month = 0,1,2 (0 - январь, 1 - февраль, 2 - март)
    # Собираем зарплаты всех работников за этот месяц
    salaries_this_month = [salary[worker][month] for worker in range(12)]
    max_salary = max(salaries_this_month)

    # Находим ВСЕХ работников с максимальной зарплатой
    workers_with_max = []
    for worker in range(12):
        if salary[worker][month] == max_salary:
            workers_with_max.append(worker + 1)  # +1 потому что работники 1..12

    # Форматируем вывод
    if len(workers_with_max) == 1:
        worker_str = str(workers_with_max[0])
    else:
        worker_str = ", ".join(map(str, workers_with_max))

    print(f"Месяц {month+1}: работник(и) {worker_str} (зарплата: {max_salary} руб.)")
