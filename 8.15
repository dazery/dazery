import random

m = random.uniform(0.52, 33.7)


if not (0.52 <= m <= 33.7):
    print("Ошибка: m должно быть в диапазоне [0.52, 33.7].")
else:
    for x in range(1, 101):  # x от 1 до 100
        y = (x**2+100)/(x+200)
        if y < m:
            print(f"x = {x}: y = {y:.6f}")
        else:
            break  # Так как последовательность возрастает, дальше все y ≥ m
