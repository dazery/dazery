word = "муха"
target = "слон"

# Используем генератор списка для замены букв
result = ''.join([target[i] for i in range(len(word))])
#join - Объединяем все буквы списка в одну строку без разделителей
#len - Узнаём длину исходного слова
#range Создаём последовательность индексов от 0 до 3.
#for i in range Проходим по каждому индексу и берём букву из слова target
print(result)
