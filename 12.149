text = "привет сегодня в магазине я потратил 1200 рублей"

# Подсчитываем количество цифр
count = 0
for char in text:#Цикл for char in text: проходит по строке символ за символом.
    if char.isdigit():
#isdigit Смотрит в таблице символов Юникода, относится ли этот символ к категории "цифра"
        count += 1

print(f"Количество цифр в тексте: {count}")
