import random

a = random.uniform(0, 2)

if not (1 < a <= 1.5):
    print("Ошибка")
else:
    n = 2
    while True:
        y = 1 + 1 / n  # Вычисляем текущий член последовательности
        if y < a:  # Если текущий член меньше a — нашли ответ
            break
        n += 1  # Переходим к следующему n

    print(f"Наименьшее n: {n}")
    print(f"Значение 1 + 1/{n} = {y:.6f} < {a}")
