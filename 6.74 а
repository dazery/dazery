import random
n = random.randint(1,999)
print(n)
if n<=0:
    print(0)
else:
    t = n
    while t%3 == 0:
        # Если после всех делений осталось 1, значит, исходное число — степень тройки
        t = t//3
    if t == 1:
        print("является степнью 3")
    else:
        print("не является степенью 3")
