a = 1
b = 10000
best_number = 1
max_sum = 0
for num in range(a, b + 1):
    summa = 0
    for delitel in range(1, num + 1):
        if num % delitel == 0:
            summa = summa + delitel

        # Если нашли сумму больше - запоминаем
    if summa > max_sum:
        max_sum = summa
        best_number = num

print(best_number)
print(max_sum)
