import random
n = random.randint(1, 100000000)
print(n)
hi2 = False
hi5 = False
while n>2:
    i = n%10
    if i == 2:
        hi2 = True
    elif i == 5:
        hi5 = True
    # Если уже нашли обе цифры, можно прервать цикл досрочно
    if hi2 and hi5:
        break
    n = n//10 # Удаляем последнюю цифру"
#Удаление последней цифры нужно, чтобы последовательно обработать все цифры числа по одной 
# — от младших разрядов (справа) к старшим (слева). Без этого действия мы бы бесконечно работали с одной и той же цифрой.
if hi2 and hi5:
    print("ЕСТЬ")
else: print(0)
